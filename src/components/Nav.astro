---
import { useTranslations, type Lang } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const altLang = lang === 'hu' ? 'en' : 'hu';
const altHref = lang === 'hu' ? '/en' : '/';
const altLabel = lang === 'hu' ? 'EN' : 'HU';

const links = [
  { key: 'nav.services' as const, href: '#services' },
  { key: 'nav.portfolio' as const, href: '#portfolio' },
  { key: 'nav.about' as const, href: '#about' },
  { key: 'nav.contact' as const, href: '#contact' },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href={lang === 'en' ? '/en' : '/'} class="flex items-center gap-2.5 group">
        <img
          src="/logo.svg"
          alt="ReformIt logo"
          width="28"
          height="25"
          class="group-hover:scale-110 transition-transform duration-300"
        />
        <span class="font-bold text-lg text-white tracking-tight">
          Reform<span class="gradient-text">It</span>
        </span>
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-8">
        {links.map(({ key, href }) => (
          <a
            href={href}
            class="text-sm font-medium text-slate-400 hover:text-white transition-colors duration-200 relative group"
          >
            {t(key)}
            <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-brand-400 group-hover:w-full transition-all duration-300"></span>
          </a>
        ))}
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Language switcher -->
        <a
          href={altHref}
          class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold text-slate-400 hover:text-white glass hover:bg-white/10 transition-all duration-200 tracking-wider"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          {altLabel}
        </a>

        <a
          href="#contact"
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold gradient-bg text-white hover:opacity-90 transition-opacity duration-200 glow-sm"
        >
          {t('nav.cta')}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg glass text-slate-300 hover:text-white transition-colors"
          aria-label="Menu"
        >
          <svg id="icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="glass rounded-2xl p-4 mt-2 flex flex-col gap-1">
        {links.map(({ key, href }) => (
          <a
            href={href}
            class="px-4 py-2.5 rounded-xl text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all duration-200 mobile-menu-link"
          >
            {t(key)}
          </a>
        ))}
        <div class="border-t border-white/10 mt-2 pt-2 flex items-center gap-2">
          <a href="#contact" class="flex-1 py-2.5 rounded-xl text-sm font-semibold text-center gradient-bg text-white mobile-menu-link">
            {t('nav.cta')}
          </a>
          <a href={altHref} class="px-4 py-2.5 rounded-xl text-sm font-semibold glass text-slate-300 hover:text-white transition-all">
            {altLabel}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar.classList.add('bg-dark-900/90', 'backdrop-blur-xl', 'border-b', 'border-white/5', 'shadow-2xl');
    } else {
      navbar.classList.remove('bg-dark-900/90', 'backdrop-blur-xl', 'border-b', 'border-white/5', 'shadow-2xl');
    }
  });

  // Mobile menu
  btn.addEventListener('click', () => {
    const open = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', open);
    iconOpen.classList.toggle('hidden', !open);
    iconClose.classList.toggle('hidden', open);
  });

  // Close on link click
  document.querySelectorAll('.mobile-menu-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
